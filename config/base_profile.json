{
  "profile_version": "1.1.0",
  "model": {
    "path": "weights/best.onnx",
    "backend": "onnxruntime",
    "providers": [
      "CUDAExecutionProvider",
      "CPUExecutionProvider"
    ],
    "task": "segmentation",
    "input_size": 640,
    "preprocess": {
      "type": "letterbox",
      "normalize": true,
      "color_format": "RGB",
      "padding_value": 114
    },
    "output_format": {
      "type": "yolo_seg_proto",
      "box_format": "xyxy",
      "has_objectness": true,
      "class_encoding": "id",
      "num_classes": 1,
      "num_mask_coeffs": 32
    },
    "postprocess": {
      "conf_threshold": 0.4,
      "iou_threshold": 0.5,
      "target_class_ids": [
        0
      ],
      "mask_threshold": 0.5,
      "crop_mask_to_bbox": true,
      "min_contour_area": 1.0,
      "contour_mode": "largest"
    }
  },
  "region": {
    "frame_width": 1280,
    "frame_height": 720,
    "roi": {
      "x": 0,
      "y": 0,
      "w": 1280,
      "h": 720
    }
  },
  "collection": {
    "trigger_band": {
      "position_ratio": 0.5,
      "thickness_ratio": 0.25,
      "min_overlap_ratio": 0.1,
      "pending_ttl_frames": 3,
      "allow_inside_band_trigger": true
    },
    "tracker": {
      "type": "centroid",
      "max_jump_px": 80.0,
      "ttl_frames": 10,
      "min_hits": 2,
      "max_reverse_px": 5.0,
      "max_area_ratio_change": 3.0
    }
  },
  "inspection": {
    "mode": "auto_baseline",
    "defect_policy": {
      "min_violated_dimensions": 1,
      "score_dimension_count": 2
    },
    "auto_baseline": {
      "lower_percentile": "p2",
      "upper_percentile": "p98",
      "rules_version": "geometry_v1",
      "calibration": {
        "min_valid_records": 45,
        "min_inlier_ratio": 0.7,
        "max_outlier_ratio": 0.3,
        "outlier": {
          "modified_z_score_threshold": 3.5,
          "iqr_multiplier": 1.5
        }
      }
    },
    "average_ratio": {
      "width_min_ratio": 0.84,
      "width_max_ratio": 1.06,
      "length_min_ratio": 0.94,
      "length_max_ratio": 1.1
    },
    "local_defect": {
      "enabled": true,
      "canonical_width": 256,
      "canonical_height": 64,
      "min_bar_aspect_ratio": 2.0,
      "min_endpoint_x_separation_ratio": 0.25,
      "zone_left": [
        0.0,
        0.33
      ],
      "zone_middle": [
        0.33,
        0.66
      ],
      "zone_right": [
        0.66,
        1.0
      ],
      "shape_threshold": 0.12,
      "middle_shape_threshold": 0.14,
      "both_sides_threshold": 0.1,
      "severe_shape_threshold": 0.3,
      "missing_weight": 1.0,
      "extra_weight": 0.6,
      "min_zone_defect_weighted_pixels": 30.0,
      "min_template_samples": 30,
      "template_mask_threshold": 0.5,
      "min_template_area_ratio": 0.1,
      "max_template_area_ratio": 0.98,
      "min_baseline_alignment_iou_p50": 0.65,
      "min_baseline_alignment_iou_p10": 0.45,
      "max_canonicalize_failure_ratio": 0.2,
      "min_color_pixels_per_sample": 200,
      "color_enabled": true,
      "color_delta_threshold": 100.0,
      "color_abnormal_ratio_threshold": 0.15,
      "color_abnormal_ratio_margin": 0.0,
      "color_delta_p95_threshold": 115.0,
      "dark_pixel_enabled": true,
      "dark_l_threshold": 60.0,
      "dark_pixel_ratio_threshold": 0.12,
      "dark_pixel_ratio_margin": 0.0,
      "erode_mask_iterations": 1,
      "morph_kernel_size": 3,
      "min_alignment_iou": 0.35,
      "orientation_flip_x": false,
      "debug_save_canonical": false
    }
  }
}
